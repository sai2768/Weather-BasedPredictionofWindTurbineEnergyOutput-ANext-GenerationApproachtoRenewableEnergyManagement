# OpenWeather API Configuration
# Get your free API key from: https://openweathermap.org/api
# Replace 'your_api_key_here' with your actual API key in src/App.tsx

VITE_OPENWEATHER_API_KEY=your_api_key_here

# Backend URL (default for local development)
VITE_BACKEND_URL=http://localhost:5000

# Note: These environment variables are optional
# You can also directly edit src/App.tsx to set API_KEY and BACKEND_URL
